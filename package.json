{
  "name": "match-feedback-survey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --outfile=dist/server/index.js --format=esm --packages=external",
    "build": "pnpm build:client && pnpm build:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "csv-parse": "^5.6.0",
    "effect": "^3.21.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "survey-core": "^2.5.33",
    "survey-react-ui": "^2.5.33"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.25.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^8.1.4",
    "vitest": "^3.2.0"
  }
}
